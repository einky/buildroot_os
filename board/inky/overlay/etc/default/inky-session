# InkyOS session configuration -- Raspberry Pi hardware target.
# Sourced by /usr/bin/inky-session; read by the launcher. See
# package/inky-session/inky-session.sh.

# Display: push 1-bit frames to the GDEM0397T81P (SSD1677 controller) over SPI
# via runtime's C driver.
export EINKY_DISPLAY_BACKEND=spi
export EINKY_SPI_DEV=/dev/spidev0.0

# ── Panel driver bring-up knobs (SSD1677) ────────────────────────────────────
# These are read by the C driver at runtime, so they can be tuned here and
# picked up with `S95inky-session restart` -- no image rebuild. Uncomment/edit:
#   EINKY_INVERT_FRAME=1   flip if the panel comes up as a photo-negative
#                          (default 0: SSD1677 BW RAM bit 1 = white, matching
#                          the pipeline's packed_white_is_one).
#   EINKY_SPI_HZ=8000000   lower the SPI clock if writes come back garbled
#                          (default 10 MHz).
#   EINKY_SPI_DEBUG=1      log each refresh + BUSY-wait timing to the launcher log.
# export EINKY_INVERT_FRAME=1
# export EINKY_SPI_HZ=8000000
# export EINKY_SPI_DEBUG=1

# Input: read the 7 GPIO buttons directly (python-gpiod on the gpiochip
# character device). The launcher owns the buttons itself -- no xdotool / Xvfb
# injection for its own UI.
export EINKY_INPUT_SOURCE=gpio
# GPIO chip that owns the BCM lines (buttons and the panel's DC/RST/BUSY both
# use it). gpiochip0 is the SoC bank on the Pi Zero 2 W vendor kernel.
export EINKY_GPIOCHIP=/dev/gpiochip0

# Where games are scanned and where settings / cover cache persist.
export EINKY_GAMES_DIR=/opt/games
export EINKY_STATE_DIR=/var/lib/inky

# Real hardware: allow the Power menu to halt/reboot the device.
export EINKY_ALLOW_POWER=1
