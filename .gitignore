/output/
/output-*/
/.dl/
/.ccache/
/.home/

# Ren'Py-generated artifacts. The game itself is NOT vendored: it is assembled at
# build time (stock the_question from the renpy package + the InkyOS hooks and
# e-ink gui/options overrides under board/qemu/). Only those .rpy deltas are
# tracked; bytecode and per-run state are derived and recompiled on first launch
# (fine while root is writable; precompile at build time before Phase 5's
# read-only root).
*.rpyc
*.rpymc
*.rpyb
**/the_question/game/saves/
**/the_question/game/cache/
**/the_question/log.txt
**/the_question/traceback.txt
**/the_question/errors.txt

# Python bytecode (scripts/)
__pycache__/

# e2e emulator test artifacts (failure frames + serial logs); goldens ARE tracked.
/tests/.artifacts/

CLAUDE.md