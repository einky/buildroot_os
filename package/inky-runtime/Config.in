config BR2_PACKAGE_INKY_RUNTIME
	bool "inky-runtime"
	depends on BR2_PACKAGE_PYTHON3
	select BR2_PACKAGE_PYTHON_NUMPY   # frame_processor dither/pack
	select BR2_PACKAGE_PYTHON_PILLOW  # eink_receiver PNG decode
	help
	  The einky `runtime`: the single owner of the e-ink frame
	  pipeline (capture -> Floyd-Steinberg dither -> 1-bit pack ->
	  dispatch), the SPI panel driver, and the GPIO/keymap input
	  bridge (ADR 0008). InkyOS does NOT reimplement any of that --
	  it builds and installs `runtime` and runs its console scripts:

	    inky-eink-receiver  in-engine path: decode PNGs pushed by
	                        Ren'Py's eink_push_callback over the
	                        engine-capture socket, then dither +
	                        dispatch them (no second dither).
	    inky-frame          Xvfb capture -> dither -> dispatch.
	    inky-input          GPIO / TCP button reader -> keypress.

	  The package is sourced from the runtime repo (pinned commit;
	  override with INKY_RUNTIME_OVERRIDE_SRCDIR for a local checkout
	  -- ./br.sh wires this automatically when ../runtime exists).

	  https://github.com/einky/runtime

if BR2_PACKAGE_INKY_RUNTIME

config BR2_PACKAGE_INKY_RUNTIME_SPI
	bool "on-device SPI panel + GPIO input (hardware target)"
	# python-gpiod needs kernel headers >= 5.10; repeat its dependency here so
	# the select below can never fire with unmet deps (kconfig silently drops
	# the selected symbol's own selects in that case -- the colorzero trap).
	depends on BR2_TOOLCHAIN_HEADERS_AT_LEAST_5_10
	select BR2_PACKAGE_PYTHON_CFFI      # _spi_driver runtime import
	select BR2_PACKAGE_LIBGPIOD2        # _spi_driver links -lgpiod (v2 API, DC/RST/BUSY)
	# Buttons are read from the gpiochip character device (input.gpio_reader).
	# gpiozero/RPi.GPIO is unusable on kernels >= 6.6: RPi.GPIO does edge
	# detection through the legacy /sys/class/gpio interface with raw BCM
	# numbers, which fail once the gpiochip sits at a dynamic global base
	# ("export_store: invalid GPIO 5" on first hardware bring-up). python-gpiod
	# conflicts with libgpiod v1, hence LIBGPIOD2 above.
	select BR2_PACKAGE_PYTHON_GPIOD     # input.gpio_reader button events
	select BR2_PACKAGE_LIBGPIOD2_TOOLS  # gpioinfo/gpioget/gpioset for bring-up
	select BR2_PACKAGE_XDOTOOL          # input.handler keysym injection
	help
	  Cross-compile the GDEM0397T81P SPI driver C extension
	  (runtime's CFFI _spi_driver) and pull in the GPIO input
	  dependencies. Enable for the Raspberry Pi hardware target
	  (EINKY_BACKEND=spi, GPIO->xdotool input).

	  Leave this OFF for the QEMU emulator: there it drives the
	  tcp/socket preview backend and feeds input through the
	  in-engine input socket (runtime's net_sender), so neither the
	  C driver nor GPIO is needed.

endif

comment "inky-runtime needs python3"
	depends on !BR2_PACKAGE_PYTHON3
