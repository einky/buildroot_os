config BR2_PACKAGE_INKY_SESSION
	bool "inky-session"
	depends on BR2_PACKAGE_RENPY
	depends on BR2_PACKAGE_INKY_RUNTIME
	depends on BR2_PACKAGE_XSERVER_XORG_SERVER_XVFB
	help
	  InkyOS boot session. Installs a BusyBox-init service
	  (S95inky-session) that supervises the inky-launcher process --
	  restarting it on exit -- so the device boots straight into the
	  launcher UI and never drops to a shell.

	  The launcher (not this service) owns the e-ink panel and the
	  buttons for the whole uptime and spawns Ren'Py games itself,
	  bringing up Xvfb on demand and wiring the in-engine
	  eink_hook.rpy / input_hook.rpy to the runtime frame/dither +
	  input path over the engine-capture sockets (ADR 0008/0009).

	  Per-target behaviour (SPI panel vs emulator TCP preview, GPIO
	  buttons vs TCP input) is selected by /etc/default/inky-session,
	  shipped from the board overlay, which exports the EINKY_*
	  backend selectors the launcher reads.

	  Games are assembled at build time under /opt/games/<slug>/
	  (stock the_question from the renpy package + the InkyOS hooks
	  layered on top by the board post-build script), not vendored in
	  git.

comment "inky-session needs renpy + inky-runtime + Xvfb"
	depends on !BR2_PACKAGE_RENPY || !BR2_PACKAGE_INKY_RUNTIME \
		|| !BR2_PACKAGE_XSERVER_XORG_SERVER_XVFB
