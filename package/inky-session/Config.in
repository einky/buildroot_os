config BR2_PACKAGE_INKY_SESSION
	bool "inky-session"
	depends on BR2_PACKAGE_RENPY
	depends on BR2_PACKAGE_XSERVER_XORG_SERVER_XVFB
	help
	  InkyOS boot-to-game session. Installs a BusyBox-init service
	  (S95inky-session) that starts the Xvfb virtual display and
	  supervises the Ren'Py game under /opt/the_question, restarting
	  it on exit -- so the device boots straight into the game and
	  never drops to a shell.

	  The game itself ships via a rootfs overlay, not this package.

comment "inky-session needs renpy + Xvfb"
	depends on !BR2_PACKAGE_RENPY || !BR2_PACKAGE_XSERVER_XORG_SERVER_XVFB
